# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms
# theme = Catppuccin Frappe
# keybind = global:cmd+shift+\=toggle_quick_terminal
# quick-terminal-position = top

# ============================================================
# Keybindings (aligned with cmux/settings.json shortcuts)
# ============================================================
# cmux のショートカットと整合させる。
# ターミナルに対応する操作のみマッピング（browser/sidebar/workspace 系は対象外）。

# --- Tab / Surface ---
# cmux: newSurface (cmd+t) / newTab (cmd+n)
keybind = cmd+t=new_tab
keybind = cmd+n=new_tab
# cmux: closeTab (cmd+w)
keybind = cmd+w=close_surface
# cmux: closeWorkspace (cmd+shift+w) → タブ一括クローズの近似
keybind = cmd+shift+w=close_tab
# cmux: nextSurface (cmd+alt+→) / prevSurface (cmd+alt+←)
keybind = cmd+alt+right=next_tab
keybind = cmd+alt+left=previous_tab
# cmux: selectSurfaceByNumber (ctrl+1)
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8
keybind = ctrl+9=goto_tab:9

# --- Window ---
# cmux: newWindow (cmd+shift+n)
keybind = cmd+shift+n=new_window
# cmux: closeWindow (cmd+ctrl+w)
keybind = cmd+ctrl+w=close_window
# cmux: toggleFullScreen (cmd+ctrl+f)
keybind = cmd+ctrl+f=toggle_fullscreen
# cmux: quit (cmd+q)
keybind = cmd+q=quit

# --- Splits (panes) ---
# cmux: splitRight (cmd+d) / splitDown (cmd+shift+d)
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
# cmux: focusUp/Down/Left/Right (cmd+↑/↓/←/→)
keybind = cmd+up=goto_split:up
keybind = cmd+down=goto_split:down
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
# cmux: toggleSplitZoom (cmd+enter)
keybind = cmd+enter=toggle_split_zoom

# --- Config ---
# cmux: openSettings (cmd+,)
keybind = cmd+comma=open_config
# cmux: reloadConfiguration (cmd+shift+,)
keybind = cmd+shift+comma=reload_config

# ============================================================
# Behavior
# ============================================================
# タブ/ペインを閉じる際の確認ポップアップを無効化
confirm-close-surface = false